# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.onrender.com,localhost,127.0.0.1

# Database Configuration
# Render will provide DATABASE_URL automatically when you attach PostgreSQL
# You can also set it manually if using external database
DATABASE_URL=postgresql://user:password@localhost:5432/job_board_db

# Email Configuration (Optional - for production emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-mailtrap-user
EMAIL_HOST_PASSWORD=your-mailtrap-password
DEFAULT_FROM_EMAIL=noreply@jobboard.com

# Social Auth - Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Social Auth - LinkedIn OAuth (Optional)
LINKEDIN_OAUTH2_KEY=your-linkedin-key
LINKEDIN_OAUTH2_SECRET=your-linkedin-secret

# JWT Token Lifetime (in minutes and days)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# API Throttling
THROTTLE_ANON=100/day
THROTTLE_USER=1000/day

# Page Size for Pagination
PAGE_SIZE=20

# CORS Configuration (Frontend URL)
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000,http://127.0.0.1:3000

# Security Settings (Set based on DEBUG status)
# SECURE_SSL_REDIRECT is automatically set based on DEBUG value
# SESSION_COOKIE_SECURE is automatically set based on DEBUG value
# CSRF_COOKIE_SECURE is automatically set based on DEBUG value
